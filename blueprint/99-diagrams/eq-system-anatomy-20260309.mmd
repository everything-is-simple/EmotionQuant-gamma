flowchart TB

subgraph ENV["外部环境层"]
E1["A股市场<br/>交易日 / 停牌 / 涨跌停 / T+1"]
E2["数据源<br/>TuShare 主 / AKShare 备"]
E3["配置与边界<br/>config.py / DATA_PATH / blueprint"]
end

subgraph SKE["骨架系统（SoT / 治理 / 约束）"]
K1["Blueprint Full Design<br/>01-08 核心正文"]
K2["Implementation Spec<br/>当前唯一实现方案"]
K3["Execution Breakdown<br/>Phase / Task / Checklist"]
K4["固定铁律<br/>A股规则 / 不硬编码 / T+1 Open"]
end

subgraph DIG["消化系统（Data）"]
D1["L1 原始摄取<br/>raw_daily / raw_daily_basic / raw_limit_list / index"]
D2["L2 加工吸收<br/>adj_daily / market_snapshot / industry_daily / structure_daily"]
D3["L3 算法产物<br/>mss_daily / irs_daily / signals / sidecars"]
D4["L4 历史代谢物<br/>orders / trades / reports / evidence"]
D1 --> D2 --> D3 --> D4
end

subgraph SEN["感觉系统（Selector）"]
S1["Universe Snapshot<br/>全市场当日快照"]
S2["Tradability Filter<br/>上市 / ST / 停牌 / 可交易性"]
S3["Hygiene Filter<br/>上市天数 / 流动性 / 基础卫生"]
S4["Preselect Score<br/>amount / volume_ratio 模式"]
S5["Top-N Cut<br/>StockCandidate 正式候选"]
S1 --> S2 --> S3 --> S4 --> S5
end

subgraph PAS["形态系统（PAS）"]
P1["History Load<br/>候选历史窗口"]
P2["Pattern Registry<br/>BOF / BPB / PB / TST / CPB"]
P3["Detector Arbitration<br/>单形态 / ANY / 组合"]
P4["Pattern Quality<br/>质量解释层"]
P5["Reference Layer<br/>stop / target / failure"]
P6["Formal Signal<br/>最小 BUY 信号"]
P1 --> P2 --> P3 --> P4 --> P5 --> P6
end

subgraph IRS["神经排序系统（IRS）"]
I1["Industry Snapshot<br/>行业日线 / 结构快照 / 基准"]
I2["Five Layers<br/>RS / RV / RT / BD / GN"]
I3["Industry Total Score<br/>IndustryScore"]
I4["Daily Unique Rank<br/>行业唯一排序"]
I5["Signal Attach<br/>irs_score 后置附着"]
I1 --> I2 --> I3 --> I4 --> I5
end

subgraph MSS["自主神经与内分泌系统（MSS）"]
M1["Market Snapshot<br/>全市场截面"]
M2["Six Factors<br/>市场系数 / 赚钱效应 / 亏钱效应 / 连续性 / 极端 / 波动"]
M3["MarketScore<br/>score + signal"]
M4["State Layer<br/>phase / phase_trend / phase_days"]
M5["Risk Regime<br/>position_advice / risk_regime"]
M6["Overlay<br/>容量缩放 / 风险覆盖"]
M1 --> M2 --> M3 --> M4 --> M5 --> M6
end

subgraph BRO["运动执行系统（Broker）"]
B1["Signal Intake<br/>按 final_rank / priority intake"]
B2["Risk Assess<br/>账户状态 / 现金 / 持仓 / overlay"]
B3["Order Materialize<br/>PENDING / REJECTED"]
B4["T+1 Open Match<br/>撮合成交 / 拒绝"]
B5["Portfolio Apply<br/>cash / position / nav"]
B6["Exit Schedule<br/>失效 / 风控 / 到期 / force close"]
B1 --> B2 --> B3 --> B4 --> B5 --> B6
end

subgraph BLOOD["血液系统（正式契约与追溯）"]
C1["StockCandidate<br/>Selector -> PAS"]
C2["Signal<br/>PAS -> Broker"]
C3["IndustryScore<br/>IRS -> Rank Attach"]
C4["MarketScore<br/>MSS -> Overlay"]
C5["Order / Trade<br/>Broker -> L4"]
C6["run_id / signal_id / order_id / trade_id<br/>全链路追溯"]
end

subgraph MEM["记忆系统（Backtest / Report / Evidence）"]
R1["Backtest Engine<br/>统一时钟推进"]
R2["Broker Kernel Reuse<br/>回测 / 纸上交易同核"]
R3["Report / Attribution<br/>收益 / 回撤 / 环境 / 失败原因"]
R4["Gate / Evidence<br/>GO / NO-GO / records / evidence"]
R1 --> R2 --> R3 --> R4
end

subgraph IMM["免疫系统（质量门控）"]
Q1["Preflight<br/>docs / config / repo checks"]
Q2["Tests<br/>unit / integration / patches"]
Q3["Contract Checks<br/>formal / sidecar / trace 一致性"]
Q4["A股规则检查<br/>T+1 / 涨跌停 / 停牌 / 交易日"]
Q5["Design Freeze Discipline<br/>先钉职责边界，再决定字段升格"]
Q1 --> Q2 --> Q3 --> Q4 --> Q5
end

