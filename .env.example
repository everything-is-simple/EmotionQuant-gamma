# EmotionQuant 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# Linux/macOS: cp .env.example .env
# Windows PowerShell: Copy-Item .env.example .env

# ========================================
# 数据源配置（TuShare 主 + AKShare 备）
# ========================================
# TuShare API Token（单通道，architecture-master §6/§7）
TUSHARE_TOKEN=
# 主通道（10000 网关；可选）
TUSHARE_PRIMARY_TOKEN=
TUSHARE_PRIMARY_HTTP_URL=
# 兜底通道（官方；可选）
TUSHARE_FALLBACK_TOKEN=
TUSHARE_FALLBACK_HTTP_URL=

# TuShare API 限流（每分钟调用次数）
TUSHARE_RATE_LIMIT_PER_MIN=300

# AKShare 为备用数据源，TuShare 不可用时自动降级
# AKShare 无需 token，此处仅控制降级行为
AKSHARE_ENABLED=true

# ========================================
# 数据路径配置
# ========================================
# 数据根目录（DuckDB 单库 + 日志，仓库外独立目录）
# 实际部署建议：G:\EmotionQuant_data 或 /data/emotionquant
# 若留空则回退到 ~/.emotionquant/data
# DuckDB 文件路径由 config.py 计算：${DATA_PATH}/emotionquant.duckdb
DATA_PATH=

# 临时目录（工作副本、pytest、ruff/mypy cache、临时导出）
# 实际部署建议：G:\EmotionQuant-temp 或 /tmp/emotionquant
TEMP_PATH=

# 日志目录（可选，默认 ${DATA_PATH}/logs）
LOG_PATH=

# 本地 raw 历史库（可选）。
# 配置后可直接执行：python main.py fetch --from-raw-db %RAW_DB_PATH%
# 若命令行未显式传参，main.py fetch 会优先读取此路径。
RAW_DB_PATH=

# ========================================
# 系统配置
# ========================================
# 仓库远端地址（统一入口，避免在多个文档中硬编码）
REPO_REMOTE_URL=https://github.com/everything-is-simple/EmotionQuant-gamma
# 仓库备份远端地址
REPO_BACKUP_REMOTE_URL=https://gitee.com/wangweiyun2233/EmotionQuant-gamma

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 运行环境：development, production
ENVIRONMENT=development

# ========================================
# 漏斗开关（architecture-master §2.1）
# ========================================
# MSS 市场情绪开关（v0.01 默认关闭，消融验证后启用）
ENABLE_MSS_GATE=false
# IRS 行业轮动过滤（v0.01 默认关闭，消融验证后启用）
ENABLE_IRS_FILTER=false
# 基因库过滤（v0.01 强制关闭，v0.02 前禁止启用）
ENABLE_GENE_FILTER=false
ENABLE_DTT_MODE=true
PIPELINE_MODE=dtt

# ========================================
# 回测与交易参数（对齐 rebuild-v0.01 §5 + config.py）
# ========================================
BACKTEST_INITIAL_CASH=1000000

# 费用模型
COMMISSION_RATE=0.0003
MIN_COMMISSION=5.0
STAMP_DUTY_RATE=0.001
TRANSFER_FEE_RATE=0.00002
SLIPPAGE_BPS=0.001

# 风控参数（rebuild-v0.01 §5）
STOP_LOSS_PCT=0.05
TRAILING_STOP_PCT=0.08
RISK_PER_TRADE_PCT=0.008
MAX_POSITION_PCT=0.10
MAX_POSITIONS=10

# 回测评估
RISK_FREE_RATE=0.015

# ========================================
# Selector / Strategy 默认参数
# ========================================
# MSS gate mode:
# - bearish_only: 仅 BEARISH 禁止建仓
# - bullish_required: 仅 BULLISH 允许建仓
# - soft_gate: BEARISH 禁止，NEUTRAL 缩池，BULLISH 正常
MSS_VARIANT=zscore_weighted6
MSS_GATE_MODE=bearish_only
MSS_SOFT_GATE_CANDIDATE_TOP_N=30
IRS_TOP_N=10
IRS_FACTOR_MODE=rsrvrtbdgn
IRS_RT_LOOKBACK_DAYS=5
IRS_TOP_RANK_THRESHOLD=3
IRS_FACTOR_WEIGHT_RS=0.30
IRS_FACTOR_WEIGHT_RV=0.25
IRS_FACTOR_WEIGHT_RT=0.15
IRS_FACTOR_WEIGHT_BD=0.15
IRS_FACTOR_WEIGHT_GN=0.15
MSS_BULLISH_THRESHOLD=65
MSS_BEARISH_THRESHOLD=35
DTT_VARIANT=v0_01_dtt_pattern_plus_irs_score
DTT_SCORE_FILL=50
DTT_TOP_N=50
DTT_PATTERN_WEIGHT=0.5
DTT_IRS_WEIGHT=0.3
DTT_MSS_WEIGHT=0.2
# TuShare amount 单位为千元；50000 = 5,000 万元成交额门槛
MIN_AMOUNT=50000
