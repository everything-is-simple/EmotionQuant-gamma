# EmotionQuant environment template
# Copy this file to .env and fill in local values.
# Linux/macOS: cp .env.example .env
# Windows PowerShell: Copy-Item .env.example .env

# ========================================
# Data roots
# ========================================
# Main local data root. Recommended: G:\EmotionQuant_data
DATA_PATH=

# Main temp/runtime root. Recommended: G:\EmotionQuant-temp
TEMP_PATH=

# Optional local raw DuckDB used by `main.py fetch --from-raw-db ...`
# Recommended: G:\EmotionQuant_data\duckdb\emotionquant.duckdb
RAW_DB_PATH=

# Optional log root. Default is ${DATA_PATH}/logs when left empty.
LOG_PATH=

# ========================================
# Local-first data policy
# ========================================
# Current daily flow is:
# 1. update Tongdaxin local files
# 2. import vipdoc
# 3. import static assets from T0002/hq_cache
# 4. repair L1 partitions
#
# The local Tongdaxin paths are not read directly from .env yet.
# They are passed to scripts as command-line arguments when needed.

# ========================================
# Remote fallback providers
# ========================================
# BaoStock is the preferred lightweight online gap-filling source.
# TuShare remains available as emergency fallback.
TUSHARE_TOKEN=
TUSHARE_PRIMARY_TOKEN=
TUSHARE_PRIMARY_HTTP_URL=
TUSHARE_FALLBACK_TOKEN=
TUSHARE_FALLBACK_HTTP_URL=
TUSHARE_RATE_LIMIT_PER_MIN=300

# Legacy fallback switch for AkShare-based fetcher branches.
# Keep enabled only if those branches are still needed.
AKSHARE_ENABLED=true

# ========================================
# Repository / runtime metadata
# ========================================
REPO_REMOTE_URL=https://github.com/everything-is-simple/EmotionQuant-gamma
REPO_BACKUP_REMOTE_URL=https://gitee.com/wangweiyun2233/EmotionQuant-gamma
LOG_LEVEL=INFO
ENVIRONMENT=development

# ========================================
# Runtime feature flags
# ========================================
ENABLE_MSS_GATE=false
ENABLE_IRS_FILTER=false
ENABLE_GENE_FILTER=false
ENABLE_DTT_MODE=true
PIPELINE_MODE=dtt

# ========================================
# Backtest / broker parameters
# ========================================
BACKTEST_INITIAL_CASH=1000000
COMMISSION_RATE=0.0003
MIN_COMMISSION=5.0
STAMP_DUTY_RATE=0.001
TRANSFER_FEE_RATE=0.00002
SLIPPAGE_BPS=0.001
STOP_LOSS_PCT=0.05
TRAILING_STOP_PCT=0.08
RISK_PER_TRADE_PCT=0.008
MAX_POSITION_PCT=0.10
MAX_POSITIONS=10
RISK_FREE_RATE=0.015

# ========================================
# Selector / strategy parameters
# ========================================
MSS_VARIANT=zscore_weighted6
MSS_GATE_MODE=bearish_only
MSS_SOFT_GATE_CANDIDATE_TOP_N=30
IRS_TOP_N=10
IRS_FACTOR_MODE=rsrvrtbdgn
IRS_RT_LOOKBACK_DAYS=5
IRS_TOP_RANK_THRESHOLD=3
IRS_FACTOR_WEIGHT_RS=0.30
IRS_FACTOR_WEIGHT_RV=0.25
IRS_FACTOR_WEIGHT_RT=0.15
IRS_FACTOR_WEIGHT_BD=0.15
IRS_FACTOR_WEIGHT_GN=0.15
MSS_BULLISH_THRESHOLD=65
MSS_BEARISH_THRESHOLD=35
DTT_VARIANT=v0_01_dtt_pattern_plus_irs_score
DTT_SCORE_FILL=50
DTT_TOP_N=50
DTT_PATTERN_WEIGHT=0.5
DTT_IRS_WEIGHT=0.3
DTT_MSS_WEIGHT=0.2
MIN_AMOUNT=50000
